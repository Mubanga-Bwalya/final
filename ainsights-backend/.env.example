; Example environment variables for A-Insights backend (development)

; JWT signing key – set to a strong, unique value in real deployments
AINSIGHTS_SECRET_KEY=change-me-in-production

; Optional: minimum fraction of model features that should be populated
; before predictions are considered reliable. Defaults to 0.6 if unset.
; AINSIGHTS_MIN_FEATURE_COVERAGE=0.6

